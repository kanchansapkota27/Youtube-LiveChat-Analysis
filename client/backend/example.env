# MongoDB — replica set required for change streams (SSE).
# When running via docker compose: mongodb://localhost:27017/?replicaSet=rs0
# When running MongoDB locally without Docker: mongodb://localhost:27017
MONGO_URL=mongodb://localhost:27017/?replicaSet=rs0
KAFKA_SERVER=localhost:9092
RAW_TOPIC=raw
MAX_SESSIONS=3
HEADLESS=false
EMOJI_MODE=EMOJI # TEXT or EMOJI 
